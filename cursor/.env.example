oDATABASE_URL="postgresql://user:password@localhost:5432/twitter_clone?schema=public"
JWT_SECRET="sua-chave-secreta-longa-e-aleatoria-aqui"

# Opcional: ao rodar db:seed, fazer este usuário seguir todos os usuários de seed (use o username)
# SEED_FOLLOW_FOR_USER=seu_username

# Opcional: storage em nuvem (avatar e imagens de posts)
# UPLOAD_PROVIDER=local
# Para S3: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, S3_BUCKET
# Para Cloudinary: CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
